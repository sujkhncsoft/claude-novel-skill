# =============================================================================
# AI 백엔드 분리 (claude | gemini | codex | agent | copilot)
# 각 단계마다 다른 CLI를 쓸 수 있습니다. 루트 .env 한 곳에 모아 두어도 됩니다.
# =============================================================================

# ── 디자인 (pnpm design) — design/*.md 생성 (주인공·장별 개요 등)
DESIGN_AI=claude
# 장 개요 장 수 (기본 20). 예: 13장만 생성하려면
# DESIGN_CHAPTER_COUNT=13

# ── 집필·작업 (pnpm dev, pnpm start) — LangGraph Supervisor → Worker CLI
# 루트 .env 를 로드합니다 (src/loadEnv.js, scripts/dev.js).
SUPERVISOR_AI=claude
WORKER_AI=claude

# =============================================================================
# 컨셉 스크립트 옵션
# =============================================================================
# concept: design/ 폴더도 컨셉에 맞게 고치려면 1
# CONCEPT_INCLUDE_DESIGN=1

# concept: 한 번에 처리할 최대 파일 수 (테스트용)
# CONCEPT_LIMIT=5

# LangGraph Worker 컨텍스트에 루트 concept.md 합침 (기본 on). 끄려면 false
# INCLUDE_CONCEPT_MD=false
# 다른 경로의 컨셉 파일: CONCEPT_FILE=path/to/concept.md

# =============================================================================
# 공통 CLI / 폴백 (scripts/lib/aiCli.js, src/cliRunner.js)
# =============================================================================
# Claude Code 배치(pnpm concept/design, pnpm dev): 권한 우회 + 비질문 접두(기본). 되묻기만 끄려면 CLAUDE_YOLO=0
# CLAUDE_YOLO=0
# CLAUDE_YOLO_PREFIX=
# CLI 실행 파일 전체 경로 (IDE에서 spawn ENOENT 시). npm 전역 예: ...\AppData\Roaming\npm\<이름>.cmd
# CLAUDE_CLI=
# GEMINI_CLI=
# CODEX_CLI=
# agent: 기본은 Cursor Agent (`-p --yolo --trust`, stdin). Codex 호환 CLI만 쓸 때:
# AGENT_CODEX_COMPAT=1
# AGENT_CLI=
# COPILOT_CLI=
#
# Copilot CLI (pnpm dev 등 비대화형 spawn): 터미널에서 /login 한 세션과 달리
# 자식 프로세스는 인증 정보를 못 찾는 경우가 많습니다. 아래 중 하나를 .env 에 넣으세요.
# (저장소에 커밋하지 말 것. GitHub: Settings → Developer settings → Fine-grained PAT, copilot 권한)
# COPILOT_GITHUB_TOKEN=ghp_...
# 또는: GH_TOKEN= / GITHUB_TOKEN=  (gh auth login 후 `gh auth token` 출력값도 가능)

# CLI_TIMEOUT_MS=600000
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:12b
