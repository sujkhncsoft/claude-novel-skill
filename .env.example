# =============================================================================
# AI 백엔드 분리 (claude | gemini | codex | copilot)
# 각 단계마다 다른 CLI를 쓸 수 있습니다. 루트 .env 한 곳에 모아 두어도 됩니다.
# =============================================================================

# ── 컨셉 (pnpm con) — concept.md 기준으로 저장소 내 .md 정렬
CONCEPT_AI=claude

# ── 디자인 (pnpm design) — design/*.md 생성
DESIGN_AI=claude

# ── 집필·작업 (pnpm dev / novel-agent) — LangGraph Supervisor → Worker CLI
# pnpm dev 실행 시 루트 .env 와 novel-agent/.env 가 순서대로 로드됩니다(같은 키면 novel-agent/.env 가 우선).
SUPERVISOR_AI=gemini
WORKER_AI=claude

# =============================================================================
# 컨셉 스크립트 옵션
# =============================================================================
# concept: design/ 폴더도 컨셉에 맞게 고치려면 1
# CONCEPT_INCLUDE_DESIGN=1

# concept: 한 번에 처리할 최대 파일 수 (테스트용)
# CONCEPT_LIMIT=5

# =============================================================================
# 공통 CLI / 폴백 (scripts/lib/aiCli.js, novel-agent)
# =============================================================================
# Claude Code 배치(pnpm concept/design, novel-agent): 권한 우회 + 비질문 접두(기본). 되묻기만 끄려면 CLAUDE_YOLO=0
# CLAUDE_YOLO=0
# CLAUDE_YOLO_PREFIX=
# CLI 실행 파일 전체 경로 (IDE에서 spawn ENOENT 시). npm 전역 예: ...\AppData\Roaming\npm\<이름>.cmd
# CLAUDE_CLI=
# GEMINI_CLI=
# CODEX_CLI=
# COPILOT_CLI=

# CLI_TIMEOUT_MS=600000
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:12b
