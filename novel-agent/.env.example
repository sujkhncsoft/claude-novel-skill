# =====================================================
# 장편 소설 자율 집필 에이전트 (novel-agent)
# 이 파일을 복사해 .env 로 사용하세요.
# =====================================================

# ─────────────────────────────────────────────────────
# AI CLI (claude | gemini | codex)
# ─────────────────────────────────────────────────────
SUPERVISOR_AI=gemini
WORKER_AI=claude

# ─────────────────────────────────────────────────────
# go.md (init-novel 이 프로젝트 폴더에 go.md 를 만들면 그 경로)
# ─────────────────────────────────────────────────────
GO_FILE=./my-novel/go.md

# 소설 프로젝트 루트 (novel-brain.json, manuscript/, 00-core/ 등)
# init-novel 로 만든 폴더를 가리키게 설정
NOVEL_ROOT=./my-novel

# (선택) 스킬/가이드 폴더 — 비우면 novel-agent 기준 상위의 claude-novel-skill 을 자동 탐색
# NOVEL_SKILL_ROOT=

# (선택) 추가 기획 MD 주입 (캐릭터 시트 등)
# DESIGN_DIR=./my-novel/design
# DESIGN_GLOB=**/*.md
# DESIGN_MAX_CHARS_PER_FILE=120000

# ─────────────────────────────────────────────────────
# 분량 목표 (한글 기준 글자 수, 공백 포함 여부는 stats.js 와 동일하게 셈)
# generate-tasks 가 챕터 개수를 계산할 때 사용
# ─────────────────────────────────────────────────────
TARGET_MIN_CHARS=450000
TYPICAL_CHAPTER_CHARS=10000

# ─────────────────────────────────────────────────────
# 실행 제어
# ─────────────────────────────────────────────────────
AUTO_RESTART=true
CONTINUOUS_MODE=false
WORKER_ITERATIONS=1
RECURSION_LIMIT=5000
CLI_TIMEOUT_MS=600000

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

HANDOFF_DIR=./handoff
HANDOFF_FILE=

CONTEXT_THRESHOLD=0.9
VERBOSE=true
